# Copy this file to .env and fill in your values
# cp .env.example .env

# PostgreSQL connection string
# Matches the docker-compose.yml defaults — no changes needed if using Docker
DATABASE_URL=postgresql://wallet_user:wallet_pass@localhost:5555/wallet_db

# JWT signing secret — change this to any long random string in production
JWT_SECRET=change-this-to-a-long-random-secret

# Port the Express server listens on
PORT=3001
